# Copy this file to .env and fill in private credentials locally.
# Never commit .env.

# ─── LLM / OpenAI-compatible gateway ───────────────────────
LLM_API_KEY=
LLM_API_BASE=https://api.ten-rings.adtensor.com/llm/v1
LLM_MAX_TOKENS=6000

# Pipeline model routing. Model names may point to the same gateway above.
GEMMA_MODEL=google/gemma-4-12B-it

# Optional direct Qwen routing.
QWEN_API_BASE=
QWEN_API_KEY=
QWEN_TEXT_MODEL=
QWEN_VL_MODEL=

# Optional direct DeepSeek routing.
DEEPSEEK_API_BASE=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=

# ─── Timestamped ASR / MOSS Transcribe Diarize ─────────────
MOSS_ASR_API_BASE=https://api.ten-rings.adtensor.com/llm/v1
MOSS_ASR_ENDPOINT=/audio/transcriptions
MOSS_ASR_API_KEY=
MOSS_ASR_MODEL=OpenMOSS-Team/MOSS-Transcribe-Diarize
MOSS_ASR_RESPONSE_FORMAT=text

# ─── Hatchet remote workers ────────────────────────────────
# Current Hatchet SDK configuration used by the existing worker stubs.
HATCHET_CLIENT_TOKEN=
HATCHET_CLIENT_TLS_STRATEGY=none
HATCHET_CLIENT_HOST_PORT=localhost:7070
HATCHET_CLIENT_NAMESPACE=

# ─── MinIO / S3-compatible object storage ──────────────────
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=
MINIO_BUCKET=media

# ─── JianYing Pro ──────────────────────────────────────────
JY_SKILL_ROOT=/absolute/path/to/jianying-editor-skill
JY_PROJECTS_ROOT=/absolute/path/to/JianyingPro/User Data/Projects/com.lveditor.draft
