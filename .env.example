# Copy this file to .env and fill in private credentials locally.
# Never commit .env.

# ─── LLM / OpenAI-compatible gateway ───────────────────────
LLM_API_KEY=
LLM_API_BASE=https://api.ten-rings.adtensor.com/llm/v1
LLM_MAX_TOKENS=6000

# Pipeline model routing. Model names may point to the same gateway above.
GEMMA_MODEL=google/gemma-4-12B-it

# Optional direct Qwen routing.
QWEN_API_BASE=https://api.ten-rings.adtensor.com/llm/v1
QWEN_API_KEY=
QWEN_TEXT_MODEL=Qwen/Qwen3.6-27B
QWEN_VL_MODEL=

# Optional direct DeepSeek routing.
DEEPSEEK_API_BASE=https://api.ten-rings.adtensor.com/llm/v1
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# ─── Hatchet remote workers ────────────────────────────────
# Current Hatchet SDK configuration used by the existing worker stubs.
HATCHET_CLIENT_TOKEN=
HATCHET_CLIENT_TLS_STRATEGY=
HATCHET_CLIENT_HOST_PORT=
HATCHET_CLIENT_NAMESPACE=

# ─── MinIO / S3-compatible object storage ──────────────────
MINIO_ACCESS_KEY=
MINIO_HOST=
MINIO_PORT=
MINIO_SECRET_KEY=
MINIO_USE_SSL=
MINIO_ENDPOINT=
MINIO_BUCKET=media

# ─── JianYing Pro ──────────────────────────────────────────
JY_SKILL_ROOT=
JY_PROJECTS_ROOT=